.login-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.login-header {
  text-align: center;
  margin-bottom: 80rpx;
}

.login-title {
  font-size: 72rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 20rpx;
}

.login-subtitle {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
}

.login-body {
  width: 100%;
  max-width: 600rpx;
}

.login-btn {
  width: 100%;
  border-radius: 12rpx;
  font-size: 32rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.wechat-btn {
  background-color: #07c160;
  color: #fff;
}

.phone-btn {
  background-color: #1989fa;
  color: #fff;
}

.divider {
  display: flex;
  align-items: center;
  margin: 40rpx 0;
}

.divider-line {
  flex: 1;
  height: 1px;
  background-color: rgba(255,255,255,0.3);
}

.divider-text {
  padding: 0 30rpx;
  color: rgba(255,255,255,0.6);
  font-size: 26rpx;
}

.phone-form {
  display: flex;
  flex-direction: column;
}

.input-field {
  background-color: rgba(255,255,255,0.15);
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  font-size: 30rpx;
  color: #fff;
  border: 1px solid rgba(255,255,255,0.3);
}

.input-field::placeholder {
  color: rgba(255,255,255,0.5);
}

.login-footer {
  margin-top: 80rpx;
}

.footer-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.5);
}

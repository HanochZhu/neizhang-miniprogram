.finance-window {
  height: 100%;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.filter-bar {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  background-color: #fff;
  padding: 20rpx 30rpx;
  border-bottom: 1px solid #e5e5e5;
  gap: 16rpx;
}

.filter-hint {
  width: 100%;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.filter-option {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  font-size: 26rpx;
  color: #666;
  border-radius: 8rpx;
  background-color: #f5f5f5;
}

.filter-option.active {
  background-color: #1989fa;
  color: #fff;
}

.finance-content {
  flex: 1;
  padding: 20rpx;
}

.summary-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.card-header {
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.card-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #999;
  font-weight: normal;
}

.summary-grid {
  display: flex;
  gap: 20rpx;
}

.summary-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 12rpx;
  background-color: #f8f8f8;
}

.summary-item.income .summary-amount {
  color: #07c160;
}

.summary-item.expense .summary-amount {
  color: #ee0a24;
}

.summary-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.summary-amount {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
}

.category-list {
  border-top: 1px solid #f0f0f0;
}

.category-item {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1px solid #f0f0f0;
}

.category-item:last-child {
  border-bottom: none;
}

.category-name {
  font-size: 28rpx;
  color: #333;
}

.category-amount {
  font-size: 26rpx;
  color: #666;
}

.transaction-list {
  border-top: 1px solid #f0f0f0;
}

.transaction-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1px solid #f0f0f0;
}

.transaction-item:last-child {
  border-bottom: none;
}

.tx-left {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.tx-category {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.tx-desc {
  font-size: 24rpx;
  color: #999;
}

.tx-date {
  font-size: 22rpx;
  color: #bbb;
}

.tx-amount {
  font-size: 30rpx;
  font-weight: bold;
}

.tx-amount.income {
  color: #07c160;
}

.tx-amount.expense {
  color: #ee0a24;
}

.tx-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.tx-delete {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #ccc;
  border-radius: 50%;
  background: #f5f5f5;
  flex-shrink: 0;
}

.tx-delete:active {
  background: #ee0a24;
  color: #fff;
}

.tx-edit {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #bbb;
  border-radius: 50%;
  background: #f5f5f5;
  flex-shrink: 0;
}

.tx-edit:active {
  background: #1989fa;
  color: #fff;
}

.edit-form {
  background: #fff;
  border: 1px solid #1989fa;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 10rpx;
}

.edit-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.edit-input {
  flex: 1;
  padding: 12rpx 16rpx;
  border: 1px solid #e5e5e5;
  border-radius: 8rpx;
  font-size: 26rpx;
  background: #fafafa;
}

.edit-input.number {
  max-width: 160rpx;
}

.edit-picker {
  padding: 12rpx 24rpx;
  border: 1px solid #e5e5e5;
  border-radius: 8rpx;
  font-size: 26rpx;
  background: #fafafa;
  min-width: 120rpx;
  text-align: center;
}

.edit-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 8rpx;
}

.edit-btn {
  padding: 12rpx 32rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.edit-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.edit-btn.save {
  background: #1989fa;
  color: #fff;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-text {
  display: block;
  font-size: 30rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.empty-hint {
  display: block;
  font-size: 26rpx;
  color: #bbb;
}

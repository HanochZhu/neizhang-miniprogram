.chat-window {
  height: 100%;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.message-list {
  flex: 1;
  padding: 20rpx;
}

.messages {
  display: flex;
  flex-direction: column;
}

.message {
  margin-bottom: 30rpx;
  display: flex;
}

.user-message {
  justify-content: flex-end;
}

.assistant-message {
  justify-content: flex-start;
}

.system-message {
  justify-content: center;
}

.bubble {
  max-width: 80%;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-all;
}

.user-bubble {
  background-color: #1989fa;
  color: #fff;
  border-top-right-radius: 4rpx;
}

.assistant-bubble {
  background-color: #fff;
  color: #333;
  border-top-left-radius: 4rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.system-bubble {
  background-color: #f0f0f0;
  color: #999;
  font-size: 24rpx;
}

.streaming-cursor::after {
  content: '|';
  animation: blink 1s infinite;
}

@keyframes blink {
  0%, 50% { opacity: 1; }
  51%, 100% { opacity: 0; }
}

.tool-calls {
  margin-top: 16rpx;
}

.tool-detail {
  padding: 16rpx;
  font-size: 24rpx;
  color: #666;
}

.tool-section {
  margin-bottom: 12rpx;
}

.tool-label {
  font-weight: bold;
  color: #333;
  margin-right: 8rpx;
}

.input-area {
  background-color: #fff;
  border-top: 1px solid #e5e5e5;
  padding: 16rpx 20rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.input-row {
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
}

.attach-btn, .send-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.attach-icon, .send-icon {
  width: 44rpx;
  height: 44rpx;
  opacity: 0.6;
}

.send-btn.active .send-icon {
  opacity: 1;
}

.text-input {
  flex: 1;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  max-height: 200rpx;
  min-height: 40rpx;
}

.chat-window {
  position: relative;
  width: 100%;
  height: 100%;
  min-height: 0;
  box-sizing: border-box;
  background-color: #f5f5f5;
  overflow: hidden;
}

.message-list {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 128rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

.messages {
  display: flex;
  flex-direction: column;
}

.message {
  margin-bottom: 30rpx;
  display: flex;
}

.user-message {
  justify-content: flex-end;
}

.assistant-message {
  justify-content: flex-start;
}

.system-message {
  justify-content: center;
}

.bubble {
  max-width: 80%;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-all;
}

.user-bubble {
  background-color: #1989fa;
  color: #fff;
  border-top-right-radius: 4rpx;
}

.file-bubble {
  background-color: #fff;
  padding: 8rpx;
}

.msg-image {
  max-width: 400rpx;
  border-radius: 8rpx;
  display: block;
}

.assistant-bubble {
  background-color: #fff;
  color: #333;
  border-top-left-radius: 4rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
  max-height: 70vh;
  overflow-y: auto;
}

.system-bubble {
  background-color: #f0f0f0;
  color: #999;
  font-size: 24rpx;
}

.streaming-cursor::after {
  content: '|';
  animation: blink 1s infinite;
}

@keyframes blink {
  0%, 50% { opacity: 1; }
  51%, 100% { opacity: 0; }
}

.tool-calls {
  margin-top: 16rpx;
}

.tool-detail {
  padding: 16rpx;
  font-size: 24rpx;
  color: #666;
}

.tool-section {
  margin-bottom: 12rpx;
}

.tool-label {
  font-weight: bold;
  color: #333;
  margin-right: 8rpx;
}

.confirm-card {
  margin-top: 20rpx;
  padding: 20rpx;
  background: #fff8e6;
  border: 1px solid #ffd666;
  border-radius: 12rpx;
}

.confirm-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #d48806;
  margin-bottom: 12rpx;
}

.confirm-reason {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.confirm-detail {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 20rpx;
}

.confirm-actions {
  display: flex;
  gap: 20rpx;
  justify-content: flex-end;
}

.confirm-btn {
  padding: 12rpx 32rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.confirm-cancel {
  background: #f5f5f5;
  color: #666;
}

.confirm-ok {
  background: #1989fa;
  color: #fff;
}

.confirm-status {
  margin-top: 16rpx;
  font-size: 24rpx;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
}

.confirm-status.confirmed {
  background: #f6ffed;
  color: #52c41a;
}

.confirm-status.cancelled {
  background: #fff1f0;
  color: #ff4d4f;
}

.input-area {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 30;
  box-sizing: border-box;
  background-color: #fff;
  border-top: 1px solid #e5e5e5;
  padding: 16rpx 20rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.input-row {
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
}

.attach-btn, .send-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.attach-icon {
  width: 44rpx;
  height: 44rpx;
  opacity: 0.6;
}

.send-btn {
  background: #e8e8e8;
  border-radius: 50%;
}

.send-btn.active {
  background: #1989fa;
}

.send-symbol {
  font-size: 36rpx;
  line-height: 1;
  color: #999;
  font-weight: bold;
}

.send-btn.active .send-symbol {
  color: #fff;
}

.text-input {
  flex: 1;
  width: 100%;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  height: 72rpx;
  min-height: 72rpx;
  max-height: 72rpx;
  line-height: 1.4;
  box-sizing: border-box;
}
